{
  "name": "furniture (가구 카탈로그 재빌드)",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [ { "field": "hours", "hoursInterval": 24 } ] }
      },
      "id": "sched-furniture",
      "name": "매일",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [ 240, 320 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8766/step/furniture",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "X-Token", "value": "={{ $env.TRIGGER_TOKEN }}" } ] },
        "options": { "timeout": 900000 }
      },
      "id": "http-step-furniture",
      "name": "POST /step/furniture",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [ 470, 320 ],
      "notes": "step_furniture.sh: furniture_catalog.py all 재빌드. 무료·멱등·크롤없음."
    },
    {
      "parameters": {},
      "id": "noop-done",
      "name": "완료",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [ 700, 320 ]
    }
  ],
  "connections": {
    "매일": { "main": [ [ { "node": "POST /step/furniture", "type": "main", "index": 0 } ] ] },
    "POST /step/furniture": { "main": [ [ { "node": "완료", "type": "main", "index": 0 } ] ] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
