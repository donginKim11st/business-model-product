# ── 필수 (키) ─────────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
OPENAI_API_KEY=

# ── REST 서버 바인딩 ─────────────────────────────────────
INSIGHT_HTTP_HOST=0.0.0.0      # 외부 요청 허용. 로컬만 열려면 127.0.0.1
INSIGHT_HTTP_PORT=8770

# ── LLM ──────────────────────────────────────────────────
INSIGHT_MODEL=gpt-4o-mini

# ── 배치 오케스트레이터(선택) ────────────────────────────
MONGO_URI=mongodb://localhost:27017/?directConnection=true
INSIGHTS_DB=insights
